generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String?
  role          Role      @default(COLLECTOR)
  createdAt     DateTime  @default(now())
  emailVerified DateTime?
  image         String?
  name          String?
  accounts      Account[]
  Batches       Batch[]
  sessions      Session[]
  events Events[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Events {
  id        String      @id @default(cuid())
  name      String
  createdAt DateTime    @default(now())
  Subevents Subevents[]
  userId String
  user User @relation(references: [id],fields: [userId],onDelete: Cascade)
}

model Subevents {
  id      String   @id @default(cuid())
  name    String
  Date    DateTime @default(now())
  eventId String
  Batches Batch[]
  events  Events   @relation(fields: [eventId], references: [id],onDelete: Cascade)

  @@index([name, Date])
}

model Batch {
  id        String    @id @default(cuid())
  bagNumber Int
  capacity  Int       @default(30)
  isSealed  Boolean   @default(false)
  userId    String
  eventId   String
  event     Subevents @relation(fields: [eventId], references: [id])
  user      User      @relation(fields: [userId], references: [id])
  Gifts     Gift[]

  @@unique([bagNumber, eventId])
}

model Gift {
  id        String     @id @default(cuid())
  batchId   String
  imageUrl  String
  status    GiftStatus @default(UNPROCESSED)
  amount    Int?
  sender    String?
  note      String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  batch     Batch      @relation(fields: [batchId], references: [id])

  @@index([batchId, status])
}

enum Role {
  ADMIN
  COLLECTOR
}

enum GiftStatus {
  UNPROCESSED
  PROCESSED
  FLAGGED
}
